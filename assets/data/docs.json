      "id": "cookbook-safe-last",
      "nav": "Safe last",
      "title": "Cookbook: safe last item",
      "description": "Return null for empty arrays.",
      "code": [
        "fnc last_safe(arr) ->",
        "  if (arr.len() ?= 0) ->",
        "    return null;",
        "  <-",
        "",
        "  return arr[arr.len() - 1];",
        "<-",
        "",
        "Writeln(last_safe([1, 2, 3]));"
      ]
    },
