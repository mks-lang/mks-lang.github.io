            "fnc add(a, b) ->",
            "  return a + b;",
            "<-",
            "",
            "test \"function add\" ->",
            "  expect(add(2, 3) ?= 5);",
            "<-"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "def add(a, b):",
            "    return a + b",
            "",
            "def test_math_add():",
            "    assert 1 + 1 == 2",
            "",
            "def test_function_add():",
            "    assert add(2, 3) == 5"
          ]
        }
      ]
    },
