          "code": [
            "watch x;",
            "",
            "on change x ->",
            "  Writeln(\"x changed\", x);",
            "<-",
            "",
            "var x =: 1;",
            "x =: 2;"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "x = 1",
            "",
            "def on_change(v):",
            "    print(\"x changed\", v)",
            "",
            "x = 2",
            "on_change(x)"
          ]
        }
      ]
