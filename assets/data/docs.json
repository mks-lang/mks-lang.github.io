        }
      ]
    },
    {
      "id": "repeat",
      "nav": "Repeat",
      "title": "repeat loops",
      "description": "Fixed-count loops, with or without an iterator variable.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "repeat 3 ->",
            "  Writeln(\"tick\");",
            "<-",
            "",
            "repeat i in 3 ->",
            "  Writeln(i);",
            "<-"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "for _ in range(3):",
            "    print(\"tick\")",
            "",
