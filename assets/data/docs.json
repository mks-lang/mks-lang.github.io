      "title": "Cookbook: sum numbers",
      "description": "Classic accumulator loop.",
      "code": [
        "var nums =: [3, 5, 8];",
        "var total =: 0;",
        "var i =: 0;",
        "",
        "while (i < nums.len()) ->",
        "  total =: total + nums[i];",
        "  i =: i + 1;",
        "<-",
        "",
        "Writeln(total);"
      ]
