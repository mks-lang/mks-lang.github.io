    {
      "id": "read-input",
      "nav": "Read",
      "title": "Read input",
      "description": "Read is a native helper registered by the interpreter.",
      "points": [
        "Read() reads one line and returns it as a string.",
        "Read(\"prompt\") prints the prompt first.",
        "Read(0) returns only the first whitespace-separated word.",
        "If input cannot be read, current behavior returns an empty string."
      ],
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "var name =: Read(\"name: \");",
            "Writeln(\"hello\", name);",
            "",
            "var line =: Read();",
            "Writeln(\"line\", line);",
            "",
            "var first =: Read(0);",
            "Writeln(\"first\", first);"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "name = input(\"name: \")",
            "print(\"hello\", name)",
            "",
            "line = input()",
            "print(\"line\", line)",
            "",
            "first = input().split()[0]",
            "print(\"first\", first)"
          ]
        }
      ]
    },
    {
      "id": "if-else",
      "nav": "If / else",
      "title": "if / else",
      "description": "Branch with arrow blocks.",
      "code": [
        "if (x > 0) ->",
        "  Writeln(\"positive\");",
        "<- else ->",
        "  Writeln(\"non-positive\");",
        "<-"
      ],
      "python": [
        "if x > 0:",
        "    print(\"positive\")",
        "else:",
        "    print(\"non-positive\")"
      ]
    },
    {
      "id": "while",
