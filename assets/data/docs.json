      "id": "cookbook-entity-counter",
      "nav": "Entity counter",
      "title": "Cookbook: mutable entity state",
      "description": "Entity methods can update self fields.",
      "code": [
        "entity Counter(value) ->",
        "  init ->",
        "    self.value =: value;",
        "  <-",
        "",
        "  method inc() ->",
        "    self.value =: self.value + 1;",
        "  <-",
        "<-",
        "",
        "var c =: Counter(0);",
        "c.inc();",
        "c.inc();",
        "Writeln(c.value);"
      ]
    },
