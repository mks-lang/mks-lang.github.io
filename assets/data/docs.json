    {
      "id": "hello",
      "nav": "Hello",
      "title": "Hello, MKS",
      "description": "Small first example using variables, stdlib, watch, and output.",
      "source": "Checked against README examples and std/math usage.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "using \"std/math\";",
            "",
            "var x =: 10;",
            "watch x;",
            "on change x ->",
            "  Writeln(\"x changed\", x);",
            "<-",
            "",
            "x =: square(x);",
            "Writeln(\"result\", x);"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "x = 10",
            "",
            "def changed():",
            "    print(\"x changed\", x)",
            "",
            "x = x * x",
            "changed()",
            "print(\"result\", x)"
          ]
        }
      ]
    },
    {
      "id": "comments",
      "nav": "Comments",
      "title": "Comments",
      "description": "Single-line comments use //.",
      "code": [
        "// one line comment",
        "var x =: 10; // inline comment",
        "Writeln(x);"
      ],
      "python": [
        "# one line comment",
        "x = 10  # inline comment",
        "print(x)"
      ]
    },
    {
      "id": "values",
      "nav": "Values",
      "title": "Values & variables",
      "description": "Core values are numbers, strings, arrays, and null. Variables use var for binding and =: for reassignment.",
      "points": [
        "Create variables with var.",
        "Reassign with =:.",
        "Swap with <-->.",
        "Arrays are indexed with [index]."
      ],
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "var n =: 42;",
            "var s =: \"hello\";",
            "var xs =: [1, 2, 3];",
            "var nothing =: null;",
            "",
            "n =: 99;",
            "xs[1] =: 20;",
            "",
            "var a =: 1;",
            "var b =: 2;",
            "a <--> b;"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "n = 42",
            "s = \"hello\"",
            "xs = [1, 2, 3]",
            "nothing = None",
            "",
            "n = 99",
            "xs[1] = 20",
            "",
            "a = 1",
            "b = 2",
            "a, b = b, a"
          ]
        }
      ]
    },
