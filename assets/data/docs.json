      "id": "cookbook-extend-array",
      "nav": "Custom array method",
      "title": "Cookbook: custom array method",
      "description": "Attach a reusable method with extend array.",
      "code": [
        "extend array ->",
        "  method first() ->",
        "    if (self.len() ?= 0) ->",
        "      return null;",
        "    <-",
        "",
        "    return self[0];",
        "  <-",
        "<-",
        "",
        "Writeln([10, 20, 30].first());"
      ]
