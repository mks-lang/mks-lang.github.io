    {
      "id": "returns",
      "nav": "Returns",
      "title": "Early return",
      "description": "Return from inside conditionals.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "fnc test(x) ->",
            "  if (x > 0) ->",
            "    return 111;",
