    {
      "id": "std-string",
      "nav": "std/string",
      "title": "Stdlib string helpers",
      "description": "std/string wraps native string methods in plain MKS functions.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "using \"std/string\";",
            "",
            "Writeln(len(\"abc\"));",
            "Writeln(lower(\"HeLLo\"));",
            "Writeln(upper(\"hello\"));",
            "Writeln(trim(\"  hi  \"));",
            "Writeln(contains(\"mks-lang\", \"lang\"));",
            "Writeln(starts_with(\"mks-lang\", \"mks\"));",
            "Writeln(ends_with(\"main.mks\", \".mks\"));",
            "Writeln(replace(\"a-b-c\", \"-\", \":\"));",
            "Writeln(split(\"a,b,c\", \",\"));",
            "Writeln(join([\"a\", \"b\", \"c\"], \"-\"));"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "print(len(\"abc\"))",
            "print(\"HeLLo\".lower())",
            "print(\"hello\".upper())",
            "print(\"  hi  \".strip())",
            "print(\"lang\" in \"mks-lang\")",
            "print(\"mks-lang\".startswith(\"mks\"))",
            "print(\"main.mks\".endswith(\".mks\"))",
            "print(\"a-b-c\".replace(\"-\", \":\"))",
            "print(\"a,b,c\".split(\",\"))",
            "print(\"-\".join([\"a\", \"b\", \"c\"]))"
          ]
        }
      ]
    },
    {
      "id": "entities",
      "nav": "Entities",
      "title": "Entities",
      "description": "Lightweight object-style values with fields and methods.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "entity Buba(name, power) ->",
            "  init ->",
            "    self.name =: name;",
            "    self.power =: power;",
            "  <-",
            "",
            "  method hello() ->",
            "    Writeln(\"Hello, I am \", self.name, \" with power \", self.power);",
            "  <-",
            "",
            "  method boost(amount) ->",
            "    self.power =: self.power + amount;",
            "  <-",
            "<-",
            "",
            "var b =: Buba(\"buba\", 12);",
            "b.hello();",
            "b.boost(5);",
            "Writeln(b.power);"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "class Buba:",
            "    def __init__(self, name, power):",
            "        self.name = name",
            "        self.power = power",
            "",
            "    def hello(self):",
            "        print(\"Hello, I am\", self.name, \"with power\", self.power)",
            "",
            "    def boost(self, amount):",
            "        self.power += amount",
            "",
            "b = Buba(\"buba\", 12)",
            "b.hello()",
            "b.boost(5)",
            "print(b.power)"
          ]
        }
      ]
    },
    {
      "id": "extend",
      "nav": "Extend",
      "title": "Extend built-ins",
      "description": "Attach new methods to built-in array values.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "extend array ->",
            "  method sum() ->",
            "    var total =: 0;",
            "    var i =: 0;",
            "",
            "    while (i < self.len()) ->",
            "      total =: total + self[i];",
            "      i =: i + 1;",
            "    <-",
            "",
            "    return total;",
            "  <-",
            "",
            "  method last() ->",
            "    if (self.len() ?= 0) ->",
            "      return null;",
            "    <-",
            "",
            "    return self[self.len() - 1];",
            "  <-",
            "<-",
            "",
            "var nums =: [1, 2, 3];",
            "Writeln(nums.sum());",
            "Writeln(nums.last());"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "def sum_list(xs):",
            "    total = 0",
            "    for x in xs:",
            "        total += x",
            "    return total",
            "",
            "def last(xs):",
            "    if len(xs) == 0:",
            "        return None",
            "    return xs[-1]",
            "",
            "nums = [1, 2, 3]",
            "print(sum_list(nums))",
            "print(last(nums))"
          ]
        }
      ]
    },
    {
      "id": "imports",
      "nav": "Imports",
      "title": "Imports with using",
      "description": "Load a module once and use its top-level names directly.",
      "points": [
        "using works with local files and std modules.",
        "The public examples use direct access to imported names.",
        "Duplicate imports are skipped."
      ],
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "// math.mks",
            "using \"std/math\";",
            "var PI =: 3;",
            "var VERSION =: \"1.0.2\";",
            "",
            "fnc get_circle_area(r) ->",
            "  return PI * r * r;",
            "<-",
            "",
            "// main.mks",
            "using \"math.mks\";",
            "Writeln(PI);",
            "Writeln(get_circle_area(2));",
            "using \"math.mks\";",
            "Writeln(VERSION);"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "# math_module.py",
            "PI = 3",
            "VERSION = \"1.0.2\"",
            "",
            "def get_circle_area(r):",
            "    return PI * r * r",
            "",
            "# main.py",
            "from math_module import PI, VERSION, get_circle_area",
            "print(PI)",
            "print(get_circle_area(2))",
            "print(VERSION)"
          ]
        }
      ]
    },
    {
      "id": "std-math",
      "nav": "std/math",
      "title": "Stdlib: math",
      "description": "Small math helpers and wrappers.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "using \"std/math\";",
            "",
            "Writeln(abs(-5));",
            "Writeln(min(10, 3));",
            "Writeln(max(10, 3));",
            "Writeln(square(4));",
            "Writeln(floor(3.8));",
            "Writeln(ceil(3.2));",
            "Writeln(round(3.6));",
            "Writeln(sqrt(16));",
            "Writeln(pow(2, 5));",
            "Writeln(sin(0));",
            "Writeln(cos(0));",
            "Writeln(rand());",
            "Writeln(randint(1, 10));"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "import math, random",
            "print(abs(-5))",
            "print(min(10, 3))",
            "print(max(10, 3))",
            "print(4 * 4)",
            "print(math.floor(3.8))",
            "print(math.ceil(3.2))",
            "print(round(3.6))",
            "print(math.sqrt(16))",
            "print(pow(2, 5))",
            "print(math.sin(0))",
            "print(math.cos(0))",
            "print(random.random())",
            "print(random.randint(1, 10))"
          ]
        }
      ]
    },
    {
      "id": "std-array",
      "nav": "std/array",
      "title": "Stdlib: array",
      "description": "Plain-MKS helper functions built on array methods and loops.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "using \"std/array\";",
            "",
            "var xs =: [1, 2, 3];",
            "Writeln(first(xs));",
            "Writeln(last(xs));",
            "Writeln(slice(xs, 1, 2));",
            "Writeln(reverse(xs));",
            "Writeln(sum(xs));",
            "",
            "fnc twice(x) -> return x * 2; <-",
            "Writeln(map(xs, twice));",
            "",
            "fnc gt1(x) -> return x > 1; <-",
            "Writeln(filter(xs, gt1));",
            "",
            "fnc add(acc, x) -> return acc + x; <-",
            "Writeln(reduce(xs, add, 0));"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "xs = [1, 2, 3]",
            "print(xs[0])",
            "print(xs[-1])",
            "print(xs[1:3])",
            "print(list(reversed(xs)))",
            "print(sum(xs))",
            "print(list(map(lambda x: x * 2, xs)))",
            "print(list(filter(lambda x: x > 1, xs)))",
            "from functools import reduce",
            "print(reduce(lambda acc, x: acc + x, xs, 0))"
          ]
        }
      ]
    },
