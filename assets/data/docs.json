            "print(test(0))"
          ]
        }
      ]
    },
    {
      "id": "recursion",
      "nav": "Recursion",
      "title": "Recursion",
      "description": "Functions can call themselves.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "fnc fact(n) ->",
            "  if (n <= 1) ->",
            "    return 1;",
            "  <-",
            "",
            "  return n * fact(n - 1);",
            "<-",
            "",
            "Writeln(fact(5));"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "def fact(n):",
            "    if n <= 1:",
            "        return 1",
            "    return n * fact(n - 1)",
            "",
            "print(fact(5))"
          ]
        }
      ]
    },
