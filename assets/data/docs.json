    {
      "id": "output",
      "nav": "Output",
      "title": "Write & Writeln",
      "description": "Basic built-in output helpers.",
      "code": [
        "Write(\"same line: \");",
        "Writeln(123);",
        "Writeln(\"name\", \"MKS\");",
        "Writeln(\"x\", 10, \"y\", 20);"
      ],
      "python": [
