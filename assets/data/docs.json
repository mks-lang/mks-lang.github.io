            "    print(i)"
          ]
        }
      ]
    },
    {
      "id": "break-continue",
      "nav": "Loop control",
      "title": "break & continue",
      "description": "Control the nearest loop.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "var x =: 0;",
            "",
            "while (x < 6) ->",
            "  x =: x + 1;",
            "",
            "  if (x ?= 2) ->",
            "    continue;",
            "  <-",
            "",
            "  if (x ?= 4) ->",
            "    break;",
            "  <-",
            "",
            "  Writeln(x);",
            "<-"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "x = 0",
            "while x < 6:",
            "    x += 1",
            "    if x == 2:",
            "        continue",
            "    if x == 4:",
            "        break",
            "    print(x)"
          ]
        }
      ]
    },
    {
      "id": "functions",
