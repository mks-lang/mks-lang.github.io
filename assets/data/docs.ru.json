      "id": "extend",
      "nav": "Extend",
      "title": "Расширение built-in типов",
      "description": "Подключай новые методы к встроенным значениям массива.",
      "tabs": [
        {
          "id": "mks",
          "label": "MKS",
          "code": [
            "extend array ->",
            "  method sum() ->",
            "    var total =: 0;",
            "    var i =: 0;",
            "",
            "    while (i < self.len()) ->",
            "      total =: total + self[i];",
            "      i =: i + 1;",
            "    <-",
            "",
            "    return total;",
            "  <-",
            "",
            "  method last() ->",
            "    if (self.len() ?= 0) ->",
            "      return null;",
            "    <-",
            "",
            "    return self[self.len() - 1];",
            "  <-",
            "<-",
            "",
            "var nums =: [1, 2, 3];",
            "Writeln(nums.sum());",
            "Writeln(nums.last());"
          ]
        },
        {
          "id": "py",
          "label": "Python",
          "code": [
            "def sum_list(xs):",
            "    total = 0",
            "    for x in xs:",
            "        total += x",
            "    return total",
            "",
            "def last(xs):",
            "    if len(xs) == 0:",
            "        return None",
            "    return xs[-1]",
            "",
            "nums = [1, 2, 3]",
            "print(sum_list(nums))",
            "print(last(nums))"
          ]
        }
      ]
    },
